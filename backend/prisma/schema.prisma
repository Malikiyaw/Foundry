generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  email
  google
  github
}

enum SubscriptionTier {
  free
  pro
  studio
}

enum Template {
  platformer
  rpg
  runner
  match3
  visualnovel
  card
  blank
}

enum GameEngine {
  phaser
  kaboom
  threejs
  pygame
  unity
}

enum FileType {
  code
  image
  audio
  json
  tilemap
}

enum AssetType {
  sprite
  tilemap
  background
  sound
  music
  model
}

enum Permission {
  view
  edit
  owner
}

enum KeyProvider {
  openai
  anthropic
  google
  replicate
  stability
  elevenlabs
  openrouter
  custom
}

model User {
  id                 String          @id @default(uuid()) @db.Uuid
  email              String          @unique
  passwordHash       String?
  provider           Provider        @default(email)
  providerId         String?
  displayName        String?
  avatarUrl          String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  subscriptionTier   SubscriptionTier @default(free)
  subscriptionExpires DateTime?

  apiKeys          ApiKey[]
  projects         Project[]
  generations      Generation[]
  collaborations   Collaboration[]
  comments         Comment[]
  invitedCollaborations Collaboration[] @relation("InvitedBy")

  @@map("users")
}

model ApiKey {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @db.Uuid
  label           String
  provider        KeyProvider
  encryptedKey    String
  keyHash         String
  monthlyBudgetUsd Decimal?   @db.Decimal(10, 2)
  usedThisMonth   Decimal     @default(0) @db.Decimal(10, 2)
  lastUsed        DateTime?
  isActive        Boolean     @default(true)
  fallbackOrder   Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Project {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @db.Uuid
  title         String
  slug          String?    @unique
  template      Template   @default(blank)
  gameEngine    GameEngine @default(phaser)
  isPublic      Boolean    @default(false)
  remixParentId String?    @db.Uuid
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  remixParent Project?         @relation("Remix", fields: [remixParentId], references: [id])
  remixes     Project[]        @relation("Remix")
  files       ProjectFile[]
  assets      Asset[]
  generations Generation[]
  comments    Comment[]
  collaborations Collaboration[]

  @@index([userId])
  @@map("projects")
}

model ProjectFile {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  path        String
  content     String   @default("")
  fileType    FileType @default(code)
  isGenerated Boolean  @default(false)
  hash        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
  @@map("project_files")
}

model Asset {
  id                String    @id @default(uuid()) @db.Uuid
  projectId         String    @db.Uuid
  filename          String
  storageUrl        String
  assetType         AssetType
  width             Int?
  height            Int?
  durationSeconds   Int?
  generatedByPrompt String?
  createdAt         DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("assets")
}

model Generation {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  userId           String   @db.Uuid
  prompt           String
  modelUsed        String?
  provider         String?
  costUsd          Decimal? @default(0) @db.Decimal(10, 6)
  tokensUsed       Int?
  responseSummary  String?
  succeeded        Boolean  @default(true)
  errorMessage     String?
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("generations")
}

model Collaboration {
  projectId    String     @db.Uuid
  userId       String     @db.Uuid
  permission   Permission @default(view)
  invitedBy    String     @db.Uuid
  createdAt    DateTime   @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser User  @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@id([projectId, userId])
  @@map("collaborations")
}

model Comment {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  userId     String   @db.Uuid
  filePath   String
  lineStart  Int
  lineEnd    Int
  content    String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("comments")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
