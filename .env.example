# Database
DATABASE_URL="postgresql://foundry:foundry@localhost:5432/foundry?schema=public"
REDIS_URL="redis://localhost:6379"

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_MASTER_KEY="change-me-to-a-64-char-hex-string"

# JWT
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# Auth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Frontend URL (for CORS + OAuth redirects)
FRONTEND_URL="http://localhost:5173"

# Port
PORT=3001

# Object Storage (S3-compatible: AWS, R2, MinIO)
STORAGE_ENDPOINT=""
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="foundry-assets"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Session
SESSION_SECRET="change-me"
